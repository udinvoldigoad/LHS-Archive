{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "concurrently -k -n laravel,vite -c green,cyan \"php artisan serve --host=127.0.0.1 --port=8000\" \"vite --host 127.0.0.1\"",
        "dev:vite": "vite --host 127.0.0.1",
        "serve": "php artisan serve --host=127.0.0.1 --port=8000"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "@vitejs/plugin-react": "^6.0.2",
        "lucide-react": "^1.20.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    }
}
